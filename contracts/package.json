{
  "name": "great-dunces-of-ritual-contracts",
  "version": "1.0.0",
  "private": true,
  "description": "ERC-721 mint contract for The Great Dunce's of Ritual (666 free mints on Ritual Chain). Designed by crankywakker.",
  "scripts": {
    "compile": "hardhat compile",
    "test":    "hardhat test",
    "deploy":  "hardhat run scripts/deploy.ts --network ritual",
    "deploy:local": "hardhat run scripts/deploy.ts --network hardhat",
    "verify":  "hardhat verify --network ritual"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@openzeppelin/contracts": "^5.1.0",
    "dotenv": "^16.4.5",
    "hardhat": "^2.22.17",
    "typescript": "^5.6.3"
  }
}
